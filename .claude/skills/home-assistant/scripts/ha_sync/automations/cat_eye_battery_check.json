{"id":"cat_eye_battery_check","alias":"猫眼电量检查","description":"每天20:00/22:00检查猫眼电量，低于20%通过客厅音箱提醒。充电中（摄像头offline）不提醒。","triggers":[{"platform":"time","at":"20:00:00"},{"platform":"time","at":"22:00:00"}],"conditions":[{"condition":"template","value_template":"{{ states('input_number.mao_yan_dian_liang') | float(100) < 20 }}"},{"condition":"template","value_template":"{{ states('camera.ezviz_cat_eye') != 'unavailable' }}"}],"actions":[{"action":"script.cat_eye_low_battery_remind"}],"mode":"single"}